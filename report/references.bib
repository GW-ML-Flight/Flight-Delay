@inproceedings{wangCalibratedExplainableFlight2026,
  title = {Calibrated and {{Explainable Flight Delay Prediction}} with {{Tree-Based Models}} in {{Machine Learning}}},
  booktitle = {Proceedings of the 2025 {{International Conference}} on {{Artificial Intelligence}} and {{Sustainable Development}}},
  author = {Wang, Zhenglin},
  date = {2026-02-04},
  series = {{{ICAISD}} '25},
  pages = {353--357},
  publisher = {Association for Computing Machinery},
  location = {New York, NY, USA},
  doi = {10.1145/3786484.3786539},
  url = {https://dl.acm.org/doi/10.1145/3786484.3786539},
  urldate = {2026-02-25},
  abstract = {Commercial air travel faces persistent delay risks that propagate costs throughout airline operations and undermine passenger rights. Beyond basic prediction, practical application requires calibrated probabilities reflecting true risk and explainable drivers to justify actions taken. This study proposes a workflow for flight delay prediction at Boston Logan Airport (BOS), centered on four tree-based models: Decision Tree, Random Forest, AdaBoost, and XGBoost. Moreover, to optimize threshold decision-making, model evaluation emphasizes not only discriminative capability through metrics like ROC-AUC and F1-score, but also probability quality measured by Brier score, applying isotonic regression if needed. The results indicate that XGBoost delivers the strongest discrimination capability with ROC-AUC of 0.939 and F1-score of 0.8837, while maintaining good probability calibration with Brier score of 0.0869. Regarding explainability, SHAP indicates that the weather conditions (wind speed, wind direction, etc.), carriers, scheduled departure times, and weekends indicator are key drivers, providing actionable insights for staffing, incident management, insurance schemes, and passenger alerts.},
  isbn = {979-8-4007-2126-7},
  file = {/Users/ozzysimpson/Zotero/storage/R6CNRQPH/Wang - 2026 - Calibrated and Explainable Flight Delay Prediction with Tree-Based Models in Machine Learning.pdf}
}

